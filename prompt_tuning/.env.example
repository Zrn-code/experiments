# ============================================================
# 實驗環境設定檔
# 複製此檔案為 .env 並填入你的值
# ============================================================

# [必填] Gemini API Key
# 從 https://aistudio.google.com/apikey 取得
GEMINI_API_KEY=your-gemini-api-key-here

# [選填] 模型名稱（預設 gemini-2.5-flash）
# MODEL_NAME=gemini-2.5-flash

# [選填] 店家名稱和 AI 助手名稱（會注入到 system prompt 中）
# STORE_NAME=蟬吃茶
# AGENT_NAME=Ezra
